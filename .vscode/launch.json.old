{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "api",
            "type": "debugpy",
            "request": "launch",
            "program": "uv",
            "args": [
                "run",
                "fastapi",
                "dev",
                "service.py"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "preLaunchTask": "uv-sync"
        }
    ]
}
